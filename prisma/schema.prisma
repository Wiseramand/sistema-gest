generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  username    String?  @unique
  password    String?
  passwordHash String?
  role        String   @default("USER")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  username         String?  @unique
  passwordHash     String?
  role             String   @default("ADMIN")
  responsibilities String[] @default([])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Student {
  id                  String   @id @default(cuid())
  name                String
  email               String?  @unique
  username            String?  @unique
  passwordHash        String?
  phone               String?
  bi                  String?
  idDocument          String?
  address             String?
  company             String?
  status              String   @default("Ativo")
  validity            String?
  nationality         String?
  photo               String?
  clientType          String   @default("Particular")
  companyId           String?
  course              String?
  role                String   @default("STUDENT")
  accessGeneratedAt   DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Trainer {
  id                String   @id @default(cuid())
  name              String
  email             String?  @unique
  username          String?  @unique
  passwordHash      String?
  phone             String?
  specialty         String?
  students          Int      @default(0)
  status            String   @default("Ativo")
  idDocument        String?
  validity          String?
  photo             String?
  address           String?
  nationality       String?
  role              String   @default("TRAINER")
  accessGeneratedAt DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  duration    String?
  category    String?
  status      String   @default("ACTIVE")
  trainerId   String?
  trainerName String?
  students    Int      @default(0)
  materials   Json     @default("[]")
  startDate   String?
  endDate     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Classroom {
  id           String   @id @default(cuid())
  name         String
  capacity     Int?
  location     String?
  description  String?
  availability String   @default("Disponível")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Enrollment {
  id          String   @id @default(cuid())
  studentId   String
  studentName String?
  courseId    String
  courseTitle String?
  status      String   @default("ACTIVE")
  enrolledAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inscription {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  course    String?
  message   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Matriculation {
  id            String   @id @default(cuid())
  studentId     String
  studentName   String?
  course        String?
  courseId      String?
  courseTitle   String?
  classroom     String?
  classroomId   String?
  trainer       String?
  trainerId     String?
  schedule      String?
  duration      String?
  paymentStatus String?  @default("Pendente")
  amountDue     Int?     @default(0)
  status        String   @default("ACTIVE")
  startDate     String?
  endDate       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Certificate {
  id               String    @id @default(cuid())
  studentId        String
  studentName      String?
  courseTitle      String
  matriculationId  String?
  status           String    @default("PENDENTE")
  generatedAt      DateTime  @default(now())
  validUntil       DateTime?
  approvedAt       DateTime?
  approvedBy       String?
  rejectedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Company {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  address       String?
  nif           String?
  description   String?
  contactPerson String?
  logo          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  userName   String?
  role       String?
  action     String
  details    String?
  targetType String?
  targetId   String?
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())
}

model Material {
  id             String   @id @default(cuid())
  name           String
  description    String?
  type           String?
  url            String?
  access         String   @default("ALL")
  uploadedBy     String?
  uploadedByName String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ChatMessage {
  id          String   @id @default(cuid())
  senderId    String?
  senderName  String?
  senderRole  String?
  recipientId String?
  content     String
  channel     String?
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Feedback {
  id                  String   @id @default(cuid())
  studentId           String?
  studentName         String?
  courseId            String?
  courseTitle         String
  institutionFeedback String?
  trainerFeedback     String?
  courseFeedback      String?
  comments            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Attendance {
  id        String   @id @default(cuid())
  courseId  String
  date      String
  trainerId String?
  records   Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, date])
}
